# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# base SQLite locale (le dossier data/ est monté sur un volume Docker)
/data/*.db
/data/*.db-shm
/data/*.db-wal
!/data/.gitkeep

# visuels sources (originaux lourds, les WebP de public/visuels font foi)
/temp_images

# settings Claude Code locaux (machine-specific)
.claude/settings.local.json
