# Notification e-mail des inscriptions (SMTP de la boîte KYS).
# Copier en `.env` et renseigner les vraies valeurs (le `.env` n'est jamais committé).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=admin@kys.technology
SMTP_PASS=changeme
SMTP_FROM=admin@kys.technology
NOTIF_TO=admin@kys.technology
